{
  "name": "plant-management",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace backend & npm run dev --workspace web & wait",
    "dev:backend": "npm run dev --workspace backend",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace backend && npm run build --workspace web",
    "check": "npm run typecheck --workspace backend && npm run typecheck --workspace web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
