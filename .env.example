# Plant-Management backend environment configuration.
# Copy this file to .env and fill in the values before starting the platform.
# .env is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Operator authentication (required — login is rejected until these are set)
# ---------------------------------------------------------------------------

# The configured operator username.
PM_ADMIN_USERNAME=admin

# Plaintext password for local development only.
# Use PM_ADMIN_PASSWORD_HASH in any environment where the password must not
# appear in process environment in plaintext.
PM_ADMIN_PASSWORD=change-this

# Preferred alternative: scrypt-derived hash.
# Format: scrypt$<hex-salt>$<hex-derived-key>
# Mutually exclusive with PM_ADMIN_PASSWORD. Hash takes precedence when set.
# PM_ADMIN_PASSWORD_HASH=scrypt$your-salt$your-derived-hex

# ---------------------------------------------------------------------------
# Session policy
# ---------------------------------------------------------------------------

# Session lifetime in milliseconds. Default: 12 hours.
PM_SESSION_TTL_MS=43200000

# Maximum failed login attempts before lockout. Default: 5.
PM_AUTH_MAX_ATTEMPTS=5

# Lockout duration in milliseconds after max attempts reached. Default: 15 minutes.
PM_AUTH_LOCKOUT_MS=900000

# Set to true when the backend is behind a reverse proxy that sets
# X-Forwarded-For. Enables IP-based rate-limit bucketing from that header.
PM_TRUST_PROXY=false
